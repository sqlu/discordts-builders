{
  "name": "@discordts/builders",
  "version": "0.1.0",
  "description": "Type-safe Discord component builders for Bun",
  "type": "module",
  "license": "MIT",
  "author": "discordts",
  "keywords": [
    "discord",
    "builders",
    "components",
    "typescript",
    "bun",
    "v2",
    "type-safe"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun x tsc --noEmit",
