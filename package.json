    "benchmark:ci": "bun run scripts/run-benchmark.ts"
  },
  "devDependencies": {
    "@discordjs/builders": "^1.14.1",
    "@types/bun": "latest",
    "discord-api-types": "^0.38.49",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "bun": ">=1.1.0"
  },
  "trustedDependencies": [],
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sqlu/discordts-builders"
  },
  "files": [
    "src"
  ]
}
